{
  "enabled": true,
  "name": "MkDocs Build",
  "description": "Run strict MkDocs build verification on demand",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m mkdocs build --strict"
  },
  "workspaceFolderName": "python-handbook",
  "shortName": "docs-mkdocs-build"
}