{
  "enabled": true,
  "name": "MkDocs Build on Docs Changes",
  "description": "Run MkDocs build verification after documentation or configuration changes",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m mkdocs build"
  },
  "workspaceFolderName": "python-handbook",
  "shortName": "docs-mkdocs-build"
}