{
  "enabled": true,
  "name": "Run Tests on Python File Changes",
  "description": "Run pytest test suite after Python files or pyproject.toml changes",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "tests/**/*.py",
      "examples/**/*.py",
      "projects/**/*.py",
      "pyproject.toml"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": ""
  }
}