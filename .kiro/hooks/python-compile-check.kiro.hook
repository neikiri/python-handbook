{
  "enabled": true,
  "name": "Python Compile Check",
  "description": "Run python -m compileall on examples, projects, and tests directories on demand",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m compileall examples projects tests"
  },
  "workspaceFolderName": "python-handbook",
  "shortName": "python-compile-check"
}