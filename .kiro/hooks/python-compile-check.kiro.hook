{
  "enabled": true,
  "name": "Python Compile Check on Save",
  "description": "Runs python -m compileall on examples, projects, and tests directories after Python files are modified",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m compileall examples projects tests"
  },
  "workspaceFolderName": "python-handbook",
  "shortName": "python-compile-check"
}